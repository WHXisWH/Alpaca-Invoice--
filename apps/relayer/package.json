{
  "name": "@alpaca/relayer",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @alpaca/database prisma:generate && pnpm --filter @alpaca/database prisma:push && pnpm exec tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @alpaca/database prisma:generate && pnpm exec tsc --noEmit -p tsconfig.json",
    "lint": "echo \"relayer lint not wired yet\"",
    "test": "pnpm exec vitest run"
  },
  "dependencies": {
    "@alpaca/database": "workspace:*",
    "@alpaca/shared": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "redis": "^5.8.2",
    "viem": "^2.21.54",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
