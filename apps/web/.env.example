# =============================================================================
# Alpaca Invoice - Web App Environment Variables
# =============================================================================

# App Configuration
NEXT_PUBLIC_APP_NAME=Alpaca Invoice
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Network Configuration
# =============================================================================
# Supported networks:
#   - Arbitrum Sepolia (421614) - recommended for CoFHE development
#   - Ethereum Sepolia (11155111) - CoFHE supported
#   - Base Sepolia (84532) - CoFHE supported
#   - Fhenix Helium (8008135) - Fhenix native testnet

NEXT_PUBLIC_RELAYER_CHAIN_ID=421614
NEXT_PUBLIC_CHAIN_NAME=Arbitrum Sepolia
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://sepolia.arbiscan.io
NEXT_PUBLIC_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# =============================================================================
# Contract Addresses
# =============================================================================
# Update these after deploying contracts

NEXT_PUBLIC_INVOICE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DISPUTE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_RELAYER_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000

# =============================================================================
# Relayer Configuration
# =============================================================================

NEXT_PUBLIC_RELAYER_URL=http://localhost:4100

# =============================================================================
# Wallet Configuration (Optional)
# =============================================================================
# WalletConnect Project ID (get from https://cloud.walletconnect.com)

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# =============================================================================
# Feature Flags (Optional)
# =============================================================================

NEXT_PUBLIC_ENABLE_ESCROW=true
NEXT_PUBLIC_ENABLE_DISPUTE=true
NEXT_PUBLIC_ENABLE_FHE_ENCRYPTION=true
